# .env
# SECURITY SETTINGS - MUST BE CHANGED IN PRODUCTION!
SECRET_KEY=a_very_secure_random_string_here_replace_me_in_prod
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# DEFAULT USERS SEEDING — required on first run, leave empty to skip seeding
# Use strong passwords (min 8 chars, uppercase + digit)
ADMIN_PASSWORD=ChangeMe@2025
USER_PASSWORD=UserPass@2025

# APIS
ALPHA_VANTAGE_API_KEY=
GEMINI_API_KEY=
OPENAI_API_KEY=
PINECONE_API_KEY=
PINECONE_INDEX_NAME=stock-reports-free

# DATABASE
MONGO_URI=mongodb://localhost:27017/stockdb
REDIS_URL=redis://localhost:6379/0
KAFKA_BROKER_URL=localhost:9092
